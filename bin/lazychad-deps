#!/bin/bash
# LazyChad Universal Dependency Installer
# Supports: Arch Linux, Debian/Ubuntu, Fedora

set -e

BOLD="\033[1m"
GREEN="\033[0;32m"
BLUE="\033[0;34m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
NC="\033[0m" # No Color

echo -e "${BOLD}${BLUE}🚀 LazyChad Dependency Installer${NC}"
echo -e "This script will detect your OS and install required external tools.\n"

if [ "$EUID" -eq 0 ]; then
    echo -e "${RED}❌ Please DO NOT run this script as root or with sudo!${NC}"
    echo -e "Run it as your normal user. It will ask for your password when installing system packages."
    exit 1
fi

# Function to check if a command exists
exists() {
    command -v "$1" >/dev/null 2>&1
}

# Detect OS
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS="$ID"
else
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
fi

# Set a fallback for NAME if it's missing from os-release
NAME="${NAME:-$OS}"

echo -e "${BOLD}${YELLOW}Detected OS: $NAME ($OS)${NC}"

# 1. Neovim Version Check & Upgrade
echo -e "\n${BOLD}${YELLOW}[1/6] Ensuring Neovim 0.11+ (Latest)...${NC}"

# Function to get neovim version
get_nvim_ver() {
    if ! exists nvim; then echo "0.0.0"; return; fi
    # Use a more robust version extraction
    nvim --version | head -n 1 | grep -oP 'v\K[0-9.]+' || echo "0.0.0"
}

is_nightly() {
    if ! exists nvim; then return 1; fi
    nvim --version | head -n 1 | grep -q "dev"
}

CURRENT_VER=$(get_nvim_ver)
MAJOR=$(echo "$CURRENT_VER" | cut -d. -f1)
MINOR=$(echo "$CURRENT_VER" | cut -d. -f2)

# Fedora users want Nightly (0.12+), others are fine with 0.11+
if [[ "$OS" == "fedora" ]]; then
    MIN_MINOR=12
else
    MIN_MINOR=11
fi

UPGRADE_NEEDED=false
if [ "$MAJOR" -eq 0 ] && [ "$MINOR" -lt "$MIN_MINOR" ]; then
    UPGRADE_NEEDED=true
fi

# If it's a dev version on Kali/AppImage, we might want to refresh it
if [[ "$OS" == "kali" ]] || [ ! -f /usr/bin/nvim ] || [[ $(file /usr/bin/nvim 2>/dev/null) == *"AppImage"* ]]; then
    if is_nightly; then
        echo -e "${YELLOW}Neovim Nightly (AppImage) detected.${NC}"
        # Check if stdin is a terminal before asking
        if [ -t 0 ]; then
            read -p "Do you want to refresh/update to the latest Nightly build? (y/N) " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                UPGRADE_NEEDED=true
            fi
        else
            echo -e "${BLUE}Non-interactive environment detected. Skipping Nightly refresh.${NC}"
        fi
    fi
fi

if [ "$UPGRADE_NEEDED" = true ]; then
    echo -e "${BLUE}Updating Neovim...${NC}"
    
    case "$OS" in
        arch|cachyos|manjaro)
            sudo pacman -S --needed --noconfirm neovim
            ;;
        debian|ubuntu|pop|kali)
            if [[ "$OS" == "kali" ]]; then
                echo -e "${YELLOW}Detected Kali Linux. Skipping PPA to prevent system instability.${NC}"
                NEED_APPIMAGE=true
            else
                echo -e "${BLUE}Updating system package lists...${NC}"
                sudo apt-get update
                echo -e "${BLUE}Ensuring software-properties-common and gnupg...${NC}"
                sudo apt-get install -y software-properties-common gnupg ca-certificates
                
                echo -e "${BLUE}Adding Neovim Unstable PPA for 0.11+ support...${NC}"
                # Use a timeout to prevent hanging on keyserver issues
                if ! sudo timeout 120s add-apt-repository -y ppa:neovim-ppa/unstable; then
                    echo -e "${RED}⚠️ PPA addition timed out or failed.${NC}"
                    echo -e "${YELLOW}Falling back to AppImage installation...${NC}"
                    NEED_APPIMAGE=true
                else
                    sudo apt-get update
                    sudo apt-get install -y neovim
                    NEED_APPIMAGE=false
                fi
            fi

            if [ "$NEED_APPIMAGE" = true ]; then
                echo -e "${BLUE}Downloading latest Neovim Nightly AppImage (x86_64)...${NC}"
                TEMP_APPIMAGE=$(mktemp)
                curl -fLo "$TEMP_APPIMAGE" https://github.com/neovim/neovim/releases/download/nightly/nvim-linux-x86_64.appimage
                chmod +x "$TEMP_APPIMAGE"
                
                # Explicitly remove old version to ensure clean slate
                # Move first to a backup if exists to prevent "Text file busy" errors
                if [ -f /usr/bin/nvim ]; then
                    sudo mv /usr/bin/nvim /usr/bin/nvim.old 2>/dev/null || true
                fi
                
                sudo mv "$TEMP_APPIMAGE" /usr/bin/nvim
                sudo rm -f /usr/bin/nvim.old /usr/local/bin/nvim 2>/dev/null || true
                echo -e "${GREEN}✅ Neovim Nightly installed via AppImage.${NC}"
            fi
            ;;
        fedora)
            echo -e "${BLUE}Ensuring Neovim Nightly on Fedora...${NC}"
            # Purge all manual AppImage locations to prevent PATH priority issues
            sudo rm -f /usr/bin/nvim /usr/local/bin/nvim 2>/dev/null || true
            
            echo -e "${BLUE}Updating COPR repositories...${NC}"
            sudo dnf install -y 'dnf-command(copr)'
            
            # Disable the broken/outdated COPR if it exists
            if sudo dnf copr list | grep -q "daniele77/neovim"; then
                echo -e "${YELLOW}Disabling broken daniele77/neovim COPR...${NC}"
                sudo dnf copr disable -y daniele77/neovim
            fi
            
            echo -e "${BLUE}Enabling agriffis/neovim-nightly COPR...${NC}"
            sudo dnf copr enable -y agriffis/neovim-nightly
            sudo dnf clean all
            echo -e "${BLUE}Synchronizing with COPR repository...${NC}"
            sudo dnf distro-sync -y neovim
            # Ensure it is installed if distro-sync didn't trigger it
            sudo dnf install -y neovim python3-neovim
            ;;
        *)
            # Fallback to AppImage only if no repo available
            echo -e "${BLUE}Downloading latest Neovim AppImage (x86_64)...${NC}"
            TEMP_APPIMAGE=$(mktemp)
            curl -fLo "$TEMP_APPIMAGE" https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.appimage
            chmod +x "$TEMP_APPIMAGE"
            
            # Atomic update logic
            if [ -f /usr/bin/nvim ]; then
                sudo mv /usr/bin/nvim /usr/bin/nvim.old 2>/dev/null || true
            fi
            sudo mv "$TEMP_APPIMAGE" /usr/bin/nvim
            sudo rm -f /usr/bin/nvim.old /usr/local/bin/nvim 2>/dev/null || true
            ;;
    esac
    echo -e "${GREEN}✅ Neovim upgraded successfully.${NC}"
else
    echo -e "${GREEN}✅ Neovim $CURRENT_VER is already up to date.${NC}"
fi

# 2. System Packages
echo -e "\n${BOLD}${YELLOW}[2/6] Checking System Packages...${NC}"

case $OS in
    arch|cachyos|manjaro)
        PKG_MANAGER="sudo pacman -S --needed --noconfirm"
        DEPS=(
            "nodejs" "npm" "git" "make" "unzip" "gcc" "cmake"
            "ttf-jetbrains-mono-nerd" "neovide"
            "python" "python-pip" "python-pipx" 
            "ripgrep" "fd" "lazygit" 
            "lua51" "luarocks" "lua-jsregexp"
            "wl-clipboard" "xclip"
        )
        check_installed() { pacman -Qs "^$1$" >/dev/null 2>&1; }
        ;;
    debian|ubuntu|pop|kali)
        PKG_MANAGER="sudo apt-get install -y"
        sudo apt-get update
        DEPS=(
            "nodejs" "npm" "git" "make" "unzip" "gcc" "cmake" "curl" "gnupg" "ca-certificates"
            "gcc-multilib" "g++-multilib" "libssl-dev" "pkg-config" "libfreetype6-dev"
            "libasound2-dev" "libexpat1-dev" "libxcb-composite0-dev" "libbz2-dev"
            "libsndio-dev" "freeglut3-dev" "libxmu-dev" "libxi-dev" "libfontconfig1-dev"
            "libxcursor-dev" "fonts-jetbrains-mono" "python3" "python3-pip" "pipx"
            "ripgrep" "fd-find" "lua5.1" "luarocks" "wl-clipboard" "xclip"
        )
        check_installed() { dpkg -l "$1" >/dev/null 2>&1; }
        ;;
    fedora)
        PKG_MANAGER="sudo dnf install -y"
        DEPS=(
            "nodejs" "npm" "git" "make" "unzip" "gcc" "cmake" "fontconfig-devel"
            "freetype-devel" "libstdc++-static" "libstdc++-devel"
            "jetbrains-mono-fonts" "python3" "python3-pip" "pipx"
            "ripgrep" "fd-find" "lua5.1" "luarocks" "wl-clipboard" "xclip"
        )
        sudo dnf install -y gcc gcc-c++ make cmake automake autoconf binutils
        check_installed() { rpm -q "$1" >/dev/null 2>&1; }
        ;;
    *)
        echo -e "${RED}Unsupported OS: $OS. Please install dependencies manually.${NC}"
        exit 1
        ;;
esac

MISSING_DEPS=()
for dep in "${DEPS[@]}"; do
    if ! check_installed "$dep"; then
        MISSING_DEPS+=("$dep")
    fi
done

if [ ${#MISSING_DEPS[@]} -gt 0 ]; then
    echo -e "${BLUE}Installing missing system packages via $OS package manager...${NC}"
    $PKG_MANAGER "${MISSING_DEPS[@]}"
else
    echo -e "${GREEN}✅ All system packages are already installed.${NC}"
fi

# 3. Rust Toolchain
echo -e "\n${BOLD}${YELLOW}[3/6] Checking Rust Toolchain (rustup)...${NC}"
if ! exists cargo; then
    echo -e "${BLUE}Installing Rust via rustup...${NC}"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    # shellcheck source=/dev/null
    [ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"
else
    echo -e "${GREEN}✅ Rust/Cargo is already installed.${NC}"
fi

# 4. Neovide (Build from source for Debian/Fedora)
echo -e "\n${BOLD}${YELLOW}[4/6] Checking Neovide GUI...${NC}"
if ! exists neovide; then
    if [[ "$OS" == "arch" || "$OS" == "cachyos" || "$OS" == "manjaro" ]]; then
        echo -e "${BLUE}Installing Neovide via pacman...${NC}"
        sudo pacman -S --needed --noconfirm neovide
    else
        echo -e "${BLUE}Building Neovide from source (this may take a few minutes)...${NC}"
        cargo install --git https://github.com/neovide/neovide
    fi
else
    echo -e "${GREEN}✅ Neovide is already installed.${NC}"
fi

# 5. Global NPM Packages
echo -e "\n${BOLD}${YELLOW}[5/6] Checking Node.js Providers...${NC}"
if ! npm list -g neovim >/dev/null 2>&1; then
    echo -e "${BLUE}Installing global npm package: neovim${NC}"
    sudo npm i -g neovim
else
    echo -e "${GREEN}✅ Global npm 'neovim' is already installed.${NC}"
fi

if ! exists tree-sitter; then
    echo -e "${BLUE}Installing global npm package: tree-sitter-cli${NC}"
    sudo npm i -g tree-sitter-cli
else
    echo -e "${GREEN}✅ Global npm 'tree-sitter-cli' is already installed.${NC}"
fi

# 6. Python Provider (pynvim)
echo -e "\n${BOLD}${YELLOW}[6/6] Checking Python Providers (pynvim)...${NC}"
if ! pipx list | grep -q "pynvim"; then
    echo -e "${BLUE}Installing pynvim via pipx...${NC}"
    pipx install pynvim --force
else
    echo -e "${GREEN}✅ Python provider (pynvim) is already installed.${NC}"
fi

echo -e "\n${BOLD}${GREEN}✨ Installation Complete!${NC}"
echo -e "Please restart your terminal and run ${BOLD}:checkhealth${NC} inside LazyChad to verify everything is working perfectly.\n"
